{
  "version": 2,
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://your-backend-url.onrender.com/api/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "https://your-backend-url.onrender.com/uploads/$1"
    },
    {
      "source": "/socket.io/(.*)",
      "destination": "https://your-backend-url.onrender.com/socket.io/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
